abinfo "build netease-cloud-music-gtk4... "
meson _build
cd _build
ninja

abinfo "install netease-cloud-music-gtk4 binary to $PKGDIR..."
ninja install
cp -v ${SRCDIR}/usr/local/bin/netease-cloud-music-gtk4 ${PKGDIR}/usr/bin/netease-cloud-music-gtk4
rm -v ${SRCDIR}/usr/local/bin/netease-cloud-music-gtk4

abinfo "fix netease-cloud-music-gtk4 shortcut..."
cp -v /usr/local/share/applications/com.gitee.gmg137.NeteaseCloudMusicGtk4.desktop /usr/share/applications/com.gitee.gmg137.NeteaseCloudMusicGtk4.desktop
rm -v /usr/local/share/applications/com.gitee.gmg137.NeteaseCloudMusicGtk4.desktop
sed -i 's/网易云音乐/网易云音乐GTK4/g' /usr/share/applications/com.gitee.gmg137.NeteaseCloudMusicGtk4.desktop
sed -i 's/網易雲音樂/网易云音乐GTK4/g' /usr/share/applications/com.gitee.gmg137.NeteaseCloudMusicGtk4.desktop

