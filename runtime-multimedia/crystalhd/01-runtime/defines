PKGNAME=libcrystalhd
PKGSEC=video
# libcrystalhd has plugins for gstreamer:
# /usr/lib/gstreamer-0.10/libgstbcmdec.so
# /usr/lib/gstreamer-1.0/libgstbcmdec.so
# but they are only useful when gstreamer is installed
# so gstreamer should be a BUILDDEP instead of PKGDEP
BUILDDEP="libcrystalhd gstreamer gst-plugins-base-0-10 gstream-0-10"
PKGDES="Crystal HD hardware decoder runtime"
