 drivers/gpu/drm/xe/xe_vm.c               |  8 ++++++--
 13 files changed, 38 insertions(+), 34 deletions(-)

diff --git a/drivers/gpu/drm/xe/regs/xe_engine_regs.h b/drivers/gpu/drm/xe/regs/xe_engine_regs.h
